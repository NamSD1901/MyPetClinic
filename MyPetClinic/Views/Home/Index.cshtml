@{
    ViewData["Title"] = "Trang Chủ";
}

<!-- ===================== HERO SECTION ===================== -->
<section class="hero" id="hero">
    <!-- Background blobs -->
    <div class="hero-blob hero-blob-1"></div>
    <div class="hero-blob hero-blob-2"></div>

    <div class="hero-container">
        <!-- Left: Text content -->
        <div class="hero-content">
            <div class="hero-badge">
                <i class="fa-solid fa-star"></i>
                Phòng khám thú y uy tín #1
            </div>

            <h1 class="hero-title">
                Chăm Sóc Thú Cưng<br>
                Với <span class="highlight">Tình Yêu</span><br>
                Chuyên Nghiệp
            </h1>

            <p class="hero-desc">
                Đội ngũ bác sĩ thú y giàu kinh nghiệm, trang thiết bị hiện đại —
                mang đến sức khỏe và hạnh phúc toàn diện cho người bạn đồng hành
                bốn chân của bạn.
            </p>

            <div class="hero-actions">
                <a href="#" class="btn-hero-primary" id="btn-datlich-hero">
                    <i class="fa-solid fa-calendar-check"></i>
                    Đặt lịch ngay
                </a>
                <a href="#services" class="btn-hero-secondary" id="btn-xemdichvu-hero">
                    <i class="fa-solid fa-stethoscope"></i>
                    Xem dịch vụ
                </a>
            </div>
        </div>

        <!-- Right: Visual card -->
        <div class="hero-visual">
            <!-- Floating badges -->
            <div class="hero-badge-floating hero-badge-floating-1">
                <div class="badge-icon green">
                    <i class="fa-solid fa-shield-heart"></i>
                </div>
                <div class="badge-text">
                    <strong>Được chứng nhận</strong>
                    <span>Bộ Y tế Thú y VN</span>
                </div>
            </div>

            <!-- Main card -->
            <div class="hero-card-main">
                <span class="paw-icon">🐾</span>
                <h3>Thú Cưng Của Bạn<br>Xứng Đáng Tốt Nhất</h3>
                <p>Chúng tôi yêu thú cưng như người thân trong gia đình</p>
                <a href="#" class="btn-hero-primary" style="font-size:0.9rem; padding: 12px 24px;">
                    <i class="fa-solid fa-paw"></i> Tìm hiểu thêm
                </a>
            </div>

            <div class="hero-badge-floating hero-badge-floating-2">
                <div class="badge-icon orange">
                    <i class="fa-solid fa-star"></i>
                </div>
                <div class="badge-text">
                    <strong>4.9/5 ⭐</strong>
                    <span>1,200+ đánh giá</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ===================== STATS SECTION ===================== -->
<section class="stats-section" id="stats">
    <div class="stats-container">
        <div class="stat-item reveal" id="stat-bacsi">
            <div class="stat-icon teal">
                <i class="fa-solid fa-user-doctor"></i>
            </div>
            <div class="stat-number" data-target="25">0</div>
            <div class="stat-label">Bác sĩ thú y</div>
        </div>

        <div class="stat-item reveal reveal-delay-1" id="stat-thucung">
            <div class="stat-icon orange">
                <i class="fa-solid fa-paw"></i>
            </div>
            <div class="stat-number" data-target="8500">0</div>
            <div class="stat-label">Thú cưng đã khám</div>
        </div>

        <div class="stat-item reveal reveal-delay-2" id="stat-namhoatdong">
            <div class="stat-icon blue">
                <i class="fa-solid fa-award"></i>
            </div>
            <div class="stat-number" data-target="10">0</div>
            <div class="stat-label">Năm hoạt động</div>
        </div>

        <div class="stat-item reveal reveal-delay-3" id="stat-danhgia">
            <div class="stat-icon purple">
                <i class="fa-solid fa-star"></i>
            </div>
            <div class="stat-number" data-target="1200">0</div>
            <div class="stat-label">Đánh giá 5 sao</div>
        </div>
    </div>
</section>

<!-- ===================== SERVICES SECTION ===================== -->
<section class="services-section" id="services">
    <div class="services-container">
        <div class="section-header reveal">
            <div class="section-tag">
                <i class="fa-solid fa-stethoscope"></i>
                Dịch vụ của chúng tôi
            </div>
            <h2 class="section-title">Chăm Sóc <span>Toàn Diện</span><br>Cho Thú Cưng</h2>
            <p class="section-desc">
                Từ khám sức khỏe định kỳ đến các ca phẫu thuật phức tạp —
                chúng tôi luôn sẵn sàng đồng hành cùng bạn và thú cưng.
            </p>
        </div>

        <div class="services-grid">
            <div class="service-card reveal" id="service-khamtongquat">
                <div class="service-icon teal">
                    <i class="fa-solid fa-heart-pulse"></i>
                </div>
                <h3 class="service-title">Khám Tổng Quát</h3>
                <p class="service-desc">
                    Kiểm tra sức khỏe toàn diện giúp phát hiện sớm các vấn đề tiềm ẩn,
                    đảm bảo thú cưng luôn khỏe mạnh và vui vẻ.
                </p>
                <a href="#" class="service-link">
                    Xem chi tiết <i class="fa-solid fa-arrow-right"></i>
                </a>
            </div>

            <div class="service-card reveal reveal-delay-1" id="service-tiemchung">
                <div class="service-icon blue">
                    <i class="fa-solid fa-syringe"></i>
                </div>
                <h3 class="service-title">Tiêm Chủng & Vaccine</h3>
                <p class="service-desc">
                    Chương trình tiêm phòng đầy đủ, đúng lịch theo tiêu chuẩn quốc tế,
                    bảo vệ thú cưng khỏi các bệnh nguy hiểm.
                </p>
                <a href="#" class="service-link">
                    Xem chi tiết <i class="fa-solid fa-arrow-right"></i>
                </a>
            </div>

            <div class="service-card reveal reveal-delay-2" id="service-phautuat">
                <div class="service-icon purple">
                    <i class="fa-solid fa-scalpel"></i>
                </div>
                <h3 class="service-title">Phẫu Thuật</h3>
                <p class="service-desc">
                    Trang thiết bị hiện đại, đội ngũ bác sĩ phẫu thuật giàu kinh nghiệm
                    đảm bảo an toàn tuyệt đối cho mọi ca mổ.
                </p>
                <a href="#" class="service-link">
                    Xem chi tiết <i class="fa-solid fa-arrow-right"></i>
                </a>
            </div>

            <div class="service-card reveal reveal-delay-3" id="service-spa">
                <div class="service-icon orange">
                    <i class="fa-solid fa-scissors"></i>
                </div>
                <h3 class="service-title">Spa & Grooming</h3>
                <p class="service-desc">
                    Dịch vụ tắm, cắt tỉa lông, làm đẹp chuyên nghiệp — giữ cho thú cưng
                    luôn sạch sẽ, thơm tho và xinh xắn nhất.
                </p>
                <a href="#" class="service-link">
                    Xem chi tiết <i class="fa-solid fa-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>
</section>

<!-- ===================== WHY US SECTION ===================== -->
<section class="whyus-section" id="whyus">
    <div class="whyus-container">
        <!-- Visual side -->
        <div class="whyus-visual reveal">
            <div class="whyus-img-wrap">
                🏥
            </div>

            <div class="whyus-floating-stat">
                <div class="wfs-icon green">
                    <i class="fa-solid fa-check"></i>
                </div>
                <div class="wfs-text">
                    <strong>100% An toàn</strong>
                    <span>Quy trình kiểm định</span>
                </div>
            </div>

            <div class="whyus-floating-stat">
                <div class="wfs-icon blue">
                    <i class="fa-solid fa-clock"></i>
                </div>
                <div class="wfs-text">
                    <strong>24/7 Hỗ trợ</strong>
                    <span>Luôn sẵn sàng giúp bạn</span>
                </div>
            </div>
        </div>

        <!-- Content side -->
        <div class="whyus-content">
            <div class="section-header reveal">
                <div class="section-tag">
                    <i class="fa-solid fa-shield-heart"></i>
                    Tại sao chọn chúng tôi
                </div>
                <h2 class="section-title">Sự Lựa Chọn<br><span>Tin Cậy</span> Của Hàng Nghìn<br>Gia Đình</h2>
                <p class="section-desc">
                    Chúng tôi không chỉ chữa bệnh — chúng tôi xây dựng mối quan hệ
                    tin tưởng lâu dài với bạn và thú cưng.
                </p>
            </div>

            <div class="whyus-list">
                <div class="whyus-item reveal" id="whyus-bacsigioikinhnghiem">
                    <div class="whyus-item-icon">
                        <i class="fa-solid fa-graduation-cap"></i>
                    </div>
                    <div class="whyus-item-text">
                        <h4>Bác Sĩ Giỏi & Giàu Kinh Nghiệm</h4>
                        <p>Đội ngũ hơn 25 bác sĩ thú y được đào tạo chuyên sâu trong và ngoài nước, luôn cập nhật kiến thức y tế mới nhất.</p>
                    </div>
                </div>

                <div class="whyus-item reveal reveal-delay-1" id="whyus-trangtbhiendai">
                    <div class="whyus-item-icon">
                        <i class="fa-solid fa-microscope"></i>
                    </div>
                    <div class="whyus-item-text">
                        <h4>Trang Thiết Bị Hiện Đại</h4>
                        <p>Máy chụp X-quang, siêu âm, xét nghiệm máu tại chỗ — kết quả nhanh, chẩn đoán chính xác trong vòng 30 phút.</p>
                    </div>
                </div>

                <div class="whyus-item reveal reveal-delay-2" id="whyus-giatrethoitam">
                    <div class="whyus-item-icon">
                        <i class="fa-solid fa-hand-holding-heart"></i>
                    </div>
                    <div class="whyus-item-text">
                        <h4>Giá Hợp Lý & Minh Bạch</h4>
                        <p>Bảng giá công khai, không phát sinh chi phí ẩn. Hỗ trợ khám miễn phí lần đầu cho thú cưng mới đến phòng khám.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
