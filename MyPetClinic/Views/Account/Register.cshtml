@model MyPetClinic.Models.RegisterViewModel
@{
    ViewData["Title"] = "Đăng Ký";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
}

<div class="auth-page">
    <div class="auth-left">
        <div class="auth-left-content">
            <a href="/" class="auth-logo">
                <div class="nav-logo-icon">
                    <i class="fa-solid fa-paw"></i>
                </div>
                <span class="auth-logo-text">My<span>Pet</span>Clinic</span>
            </a>

            <div class="auth-illustration">
                <div class="auth-big-icon">🏥</div>
                <h2>Tham gia cùng chúng tôi!</h2>
                <p>Tạo tài khoản miễn phí để trải nghiệm dịch vụ chăm sóc thú cưng chuyên nghiệp nhất Việt Nam.</p>
            </div>

            <div class="auth-features">
                <div class="auth-feature-item">
                    <div class="auth-feature-icon">
                        <i class="fa-solid fa-gift"></i>
                    </div>
                    <span>Khám miễn phí lần đầu</span>
                </div>
                <div class="auth-feature-item">
                    <div class="auth-feature-icon">
                        <i class="fa-solid fa-shield-heart"></i>
                    </div>
                    <span>Bảo mật thông tin tuyệt đối</span>
                </div>
                <div class="auth-feature-item">
                    <div class="auth-feature-icon">
                        <i class="fa-solid fa-star"></i>
                    </div>
                    <span>Ưu đãi thành viên độc quyền</span>
                </div>
            </div>
        </div>
    </div>

    <div class="auth-right">
        <div class="auth-form-wrap">
            <div class="auth-form-header">
                <h1 class="auth-title">Tạo tài khoản</h1>
                <p class="auth-subtitle">Đã có tài khoản?
                    <a asp-controller="Account" asp-action="Login" class="auth-switch-link">Đăng nhập</a>
                </p>
            </div>

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="auth-alert auth-alert-error">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    @TempData["ErrorMessage"]
                </div>
            }

            <form asp-action="Register" method="post" class="auth-form" id="form-dangky">
                @Html.AntiForgeryToken()

                <div class="form-group-auth" id="group-hoten">
                    <label asp-for="FullName" class="form-label-auth">
                        <i class="fa-solid fa-user"></i> Họ và tên
                    </label>
                    <input asp-for="FullName"
                           class="form-input-auth"
                           type="text"
                           placeholder="Nguyễn Văn A"
                           id="input-hoten"
                           autocomplete="name" />
                    <span asp-validation-for="FullName" class="form-error-auth"></span>
                </div>

                <div class="form-grid-2">
                    <div class="form-group-auth" id="group-email-register">
                        <label asp-for="Email" class="form-label-auth">
                            <i class="fa-solid fa-envelope"></i> Email
                        </label>
                        <input asp-for="Email"
                               class="form-input-auth"
                               type="email"
                               placeholder="example@email.com"
                               id="input-email-register"
                               autocomplete="email" />
                        <span asp-validation-for="Email" class="form-error-auth"></span>
                    </div>

                    <div class="form-group-auth" id="group-sodienthoai">
                        <label asp-for="PhoneNumber" class="form-label-auth">
                            <i class="fa-solid fa-phone"></i> Số điện thoại
                        </label>
                        <input asp-for="PhoneNumber"
                               class="form-input-auth"
                               type="tel"
                               placeholder="0901 234 567"
                               id="input-sodienthoai"
                               autocomplete="tel" />
                        <span asp-validation-for="PhoneNumber" class="form-error-auth"></span>
                    </div>
                </div>

                <div class="form-group-auth" id="group-password-register">
                    <label asp-for="Password" class="form-label-auth">
                        <i class="fa-solid fa-lock"></i> Mật khẩu
                    </label>
                    <div class="input-password-wrap">
                        <input asp-for="Password"
                               class="form-input-auth"
                               type="password"
                               placeholder="Ít nhất 6 ký tự"
                               id="input-password-register"
                               autocomplete="new-password" />
                        <button type="button" class="toggle-password" id="toggle-pw-register" aria-label="Hiện/ẩn mật khẩu">
                            <i class="fa-regular fa-eye" id="eye-icon-register"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="form-error-auth"></span>
                    <!-- Password strength bar -->
                    <div class="password-strength" id="pw-strength-bar" style="display:none">
                        <div class="strength-track">
                            <div class="strength-fill" id="pw-strength-fill"></div>
                        </div>
                        <span class="strength-label" id="pw-strength-label">Yếu</span>
                    </div>
                </div>

                <div class="form-group-auth" id="group-confirmpassword">
                    <label asp-for="ConfirmPassword" class="form-label-auth">
                        <i class="fa-solid fa-lock-open"></i> Xác nhận mật khẩu
                    </label>
                    <div class="input-password-wrap">
                        <input asp-for="ConfirmPassword"
                               class="form-input-auth"
                               type="password"
                               placeholder="Nhập lại mật khẩu"
                               id="input-confirmpassword"
                               autocomplete="new-password" />
                        <button type="button" class="toggle-password" id="toggle-pw-confirm" aria-label="Hiện/ẩn mật khẩu">
                            <i class="fa-regular fa-eye" id="eye-icon-confirm"></i>
                        </button>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="form-error-auth"></span>
                </div>

                <div class="form-group-auth" id="group-dieukoan">
                    <label class="checkbox-auth" id="label-dieukhoan">
                        <input asp-for="AgreeToTerms" type="checkbox" id="input-dieukhoan" />
                        <span class="checkbox-custom"></span>
                        Tôi đồng ý với <a href="#" class="auth-switch-link">Điều khoản sử dụng</a>
                        và <a href="#" class="auth-switch-link">Chính sách bảo mật</a>
                    </label>
                    <span asp-validation-for="AgreeToTerms" class="form-error-auth"></span>
                </div>

                <button type="submit" class="btn-auth-submit" id="btn-submit-dangky">
                    <i class="fa-solid fa-user-plus"></i>
                    Tạo tài khoản
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        // Toggle password - Register
        function setupToggle(toggleId, inputId, iconId) {
            document.getElementById(toggleId).addEventListener('click', function () {
                const input = document.getElementById(inputId);
                const icon = document.getElementById(iconId);
                if (input.type === 'password') {
                    input.type = 'text';
                    icon.className = 'fa-regular fa-eye-slash';
                } else {
                    input.type = 'password';
                    icon.className = 'fa-regular fa-eye';
                }
            });
        }
        setupToggle('toggle-pw-register', 'input-password-register', 'eye-icon-register');
        setupToggle('toggle-pw-confirm', 'input-confirmpassword', 'eye-icon-confirm');

        // Password strength indicator
        const pwInput = document.getElementById('input-password-register');
        const strengthBar = document.getElementById('pw-strength-bar');
        const strengthFill = document.getElementById('pw-strength-fill');
        const strengthLabel = document.getElementById('pw-strength-label');

        pwInput.addEventListener('input', function () {
            const val = this.value;
            if (!val) { strengthBar.style.display = 'none'; return; }
            strengthBar.style.display = 'flex';

            let score = 0;
            if (val.length >= 6) score++;
            if (val.length >= 10) score++;
            if (/[A-Z]/.test(val)) score++;
            if (/[0-9]/.test(val)) score++;
            if (/[^A-Za-z0-9]/.test(val)) score++;

            const levels = [
                { pct: '20%', color: '#ef4444', label: 'Rất yếu' },
                { pct: '40%', color: '#f97316', label: 'Yếu' },
                { pct: '60%', color: '#eab308', label: 'Trung bình' },
                { pct: '80%', color: '#22c55e', label: 'Mạnh' },
                { pct: '100%', color: '#0d9488', label: 'Rất mạnh' },
            ];
            const lvl = levels[Math.max(0, score - 1)];
            strengthFill.style.width = lvl.pct;
            strengthFill.style.background = lvl.color;
            strengthLabel.textContent = lvl.label;
            strengthLabel.style.color = lvl.color;
        });
    </script>
}
