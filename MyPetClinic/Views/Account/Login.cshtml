@model MyPetClinic.Models.LoginViewModel
@{
    ViewData["Title"] = "Đăng Nhập";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
}

<div class="auth-page">
    <div class="auth-left">
        <div class="auth-left-content">
            <a href="/" class="auth-logo">
                <div class="nav-logo-icon">
                    <i class="fa-solid fa-paw"></i>
                </div>
                <span class="auth-logo-text">My<span>Pet</span>Clinic</span>
            </a>

            <div class="auth-illustration">
                <div class="auth-big-icon">🐾</div>
                <h2>Chào mừng trở lại!</h2>
                <p>Đăng nhập để quản lý lịch hẹn, theo dõi sức khỏe thú cưng và nhận ưu đãi đặc biệt từ chúng tôi.</p>
            </div>

            <div class="auth-features">
                <div class="auth-feature-item">
                    <div class="auth-feature-icon">
                        <i class="fa-solid fa-calendar-check"></i>
                    </div>
                    <span>Đặt & quản lý lịch hẹn</span>
                </div>
                <div class="auth-feature-item">
                    <div class="auth-feature-icon">
                        <i class="fa-solid fa-notes-medical"></i>
                    </div>
                    <span>Xem hồ sơ sức khỏe thú cưng</span>
                </div>
                <div class="auth-feature-item">
                    <div class="auth-feature-icon">
                        <i class="fa-solid fa-bell"></i>
                    </div>
                    <span>Nhận thông báo nhắc lịch</span>
                </div>
            </div>
        </div>
    </div>

    <div class="auth-right">
        <div class="auth-form-wrap">
            <div class="auth-form-header">
                <h1 class="auth-title">Đăng nhập</h1>
                <p class="auth-subtitle">Chưa có tài khoản?
                    <a asp-controller="Account" asp-action="Register" class="auth-switch-link">Đăng ký ngay</a>
                </p>
            </div>

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="auth-alert auth-alert-error">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    @TempData["ErrorMessage"]
                </div>
            }

            <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" class="auth-form" id="form-dangnhap">
                @Html.AntiForgeryToken()

                <div class="form-group-auth" id="group-email-login">
                    <label asp-for="Email" class="form-label-auth">
                        <i class="fa-solid fa-envelope"></i> Email
                    </label>
                    <input asp-for="Email"
                           class="form-input-auth"
                           type="email"
                           placeholder="example@email.com"
                           id="input-email-login"
                           autocomplete="email" />
                    <span asp-validation-for="Email" class="form-error-auth"></span>
                </div>

                <div class="form-group-auth" id="group-password-login">
                    <label asp-for="Password" class="form-label-auth">
                        <i class="fa-solid fa-lock"></i> Mật khẩu
                    </label>
                    <div class="input-password-wrap">
                        <input asp-for="Password"
                               class="form-input-auth"
                               type="password"
                               placeholder="Nhập mật khẩu"
                               id="input-password-login"
                               autocomplete="current-password" />
                        <button type="button" class="toggle-password" id="toggle-pw-login" aria-label="Hiện/ẩn mật khẩu">
                            <i class="fa-regular fa-eye" id="eye-icon-login"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="form-error-auth"></span>
                </div>

                <div class="form-row-auth">
                    <label class="checkbox-auth" id="label-ghinhodangnhap">
                        <input asp-for="RememberMe" type="checkbox" id="input-ghinhodangnhap" />
                        <span class="checkbox-custom"></span>
                        Ghi nhớ đăng nhập
                    </label>
                    <a href="#" class="forgot-password-link" id="link-quenmatkhau">Quên mật khẩu?</a>
                </div>

                <button type="submit" class="btn-auth-submit" id="btn-submit-dangnhap">
                    <i class="fa-solid fa-right-to-bracket"></i>
                    Đăng nhập
                </button>

                <div class="auth-divider">
                    <span>hoặc đăng nhập với</span>
                </div>

                <div class="social-login-row">
                    <button type="button" class="btn-social-login" id="btn-google-login">
                        <i class="fa-brands fa-google"></i> Google
                    </button>
                    <button type="button" class="btn-social-login" id="btn-facebook-login">
                        <i class="fa-brands fa-facebook-f"></i> Facebook
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        // Toggle password visibility
        document.getElementById('toggle-pw-login').addEventListener('click', function () {
            const input = document.getElementById('input-password-login');
            const icon = document.getElementById('eye-icon-login');
            if (input.type === 'password') {
                input.type = 'text';
                icon.className = 'fa-regular fa-eye-slash';
            } else {
                input.type = 'password';
                icon.className = 'fa-regular fa-eye';
            }
        });
    </script>
}
